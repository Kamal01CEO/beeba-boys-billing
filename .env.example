# ═══════════════════════════════════════
# Billing Software — Environment Config
# ═══════════════════════════════════════
# Copy this to .env and fill in your values:
#   cp .env.example .env

# --- Google Sheets ---
# 1. Go to https://console.cloud.google.com/ → Create Project → Enable Google Sheets API
# 2. Create Service Account → Download JSON key
# 3. Rename it to service-account.json and place in credentials/
# 4. Share your Google Sheet with the service account email (editor)
GOOGLE_SHEET_ID=your_google_sheet_id_here

# --- Telegram Bot ---
# 1. Open Telegram → Search @BotFather
# 2. Send /newbot → Follow prompts → Get the token
# 3. Set it below
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Comma-separated list of Telegram user IDs allowed to use the bot
ALLOWED_USER_IDS=123456789,987654321

# --- Shop Settings ---
SHOP_NAME=Beeba Boys 1001
SHOP_ADDRESS=Your Shop Address Here
SHOP_CONTACT=+91-9876543210
BILL_FOOTER=Thank you! Visit again!

# --- Printer ---
# USB vendor and product IDs for thermal printer
# Default: 0x0416 0x5011 (common for 58mm ESC/POS printers)
# Find yours with: lsusb | grep -i printer
PRINTER_VENDOR_ID=0x0416
PRINTER_PRODUCT_ID=0x5011

# --- Server ---
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
