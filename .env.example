# ═══════════════════════════════════════
# Billing Software — Environment Config
# ═══════════════════════════════════════
# Copy this to .env and fill in your values:
#   cp .env.example .env

# --- Google Sheets ---
# 1. Go to https://console.cloud.google.com/ → Create Project → Enable Google Sheets API
# 2. Create Service Account → Download JSON key
# 3. Rename it to service-account.json and place in credentials/
# 4. Share your Google Sheet with the service account email (editor)
GOOGLE_SHEET_ID=your_google_sheet_id_here

# --- Storage ---
# Recommended for the shop laptop. On Windows data is saved under:
# %LOCALAPPDATA%\Beeba Boys 1001\data
STORAGE_BACKEND=excel
# Optional custom path (leave blank to use the safe Windows location above)
BILLING_DATA_DIR=

# --- Telegram Bot ---
# 1. Open Telegram → Search @BotFather
# 2. Send /newbot → Follow prompts → Get the token
# 3. Set it below
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Comma-separated list of Telegram user IDs allowed to use the bot
ALLOWED_USER_IDS=123456789,987654321

# --- Shop Settings ---
SHOP_NAME=Beeba Boys 1001
SHOP_ADDRESS=Your Shop Address Here
SHOP_CONTACT=
BILL_FOOTER=Thank you! Visit again!

# --- Printer ---
# USB vendor and product IDs for thermal printer
# ATPOS H-58BT detected profile: 0x0456 0x0808
# Find yours with: lsusb | grep -i printer
PRINTER_VENDOR_ID=0x0456
PRINTER_PRODUCT_ID=0x0808
PRINTER_USB_IN_ENDPOINT=0x81
PRINTER_USB_OUT_ENDPOINT=0x03
PRINTER_USB_CHUNK_BYTES=512
PRINTER_USB_CHUNK_DELAY_MS=25
PRINTER_USB_FINAL_DELAY_MS=500
PRINTER_WIDTH_DOTS=384
PRINTER_LOGO_WIDTH_DOTS=144
# Font B on H-58BT: 42 characters per line for a compact receipt.
PRINTER_CHARS=42
# H-58BT specifications do not list an auto cutter; feed for manual tear.
PRINTER_AUTO_CUT=false

# --- Server ---
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_SERVER=waitress
